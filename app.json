{
  "expo": {
    "name": "lume",
    "slug": "lume",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logoapp.png",
    "scheme": "lume",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.giordanazevedo.lume",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logoapp.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logoappcapa.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d8ffb106-2b09-4d4e-862a-d7c67794a6c3"
      }
    },
    "owner": "lume1906"
  }
}
